{
  "name": "@gns-vault/auth-sdk",
  "version": "0.1.0",
  "description": "GNS Auth SDK — Add 'Sign in with GNS' to any website in one script tag",
  "author": "GNS Foundation",
  "license": "MIT",
  "type": "module",
  "main": "./dist/gns-auth.js",
  "types": "./dist/gns-auth.d.ts",
  "exports": {
    ".": {
      "import": "./dist/gns-auth.js",
      "types": "./dist/gns-auth.d.ts"
    }
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc && node build.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist/"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "jsdom": "^26.0.0",
    "eslint": "^9.0.0",
    "esbuild": "^0.24.0"
  }
}
